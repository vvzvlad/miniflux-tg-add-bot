# Telegram bot token from @BotFather and the only username allowed to use the bot
TELEGRAM_TOKEN=123456789:AAExampleTelegramBotTokenXXXXXXXXXXXXXXX
ADMIN=your_telegram_username

# Miniflux instance and credentials.
# Either MINIFLUX_API_KEY, or both MINIFLUX_USERNAME and MINIFLUX_PASSWORD.
MINIFLUX_BASE_URL=https://miniflux.example.com
MINIFLUX_API_KEY=your_miniflux_api_key
#MINIFLUX_USERNAME=your_miniflux_username
#MINIFLUX_PASSWORD=your_miniflux_password

# RSS-Bridge feed URL template; must contain the {channel} placeholder
RSS_BRIDGE_URL=https://rss-bridge.example.com/telegram/{channel}/your_bridge_token

# Allow subscribing channels without a public username (requires RSS-Bridge support)
ACCEPT_CHANNELS_WITHOUT_USERNAME=false

# Logging: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
